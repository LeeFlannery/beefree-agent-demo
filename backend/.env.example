# Choose your LLM provider: anthropic | openai | gemini
LLM_PROVIDER=anthropic

# Fill in the key for your chosen provider — the others can stay blank
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Swap to real Beefree MCP URL when you have credentials
# Mock server runs at http://localhost:8001 by default
BEEFREE_MCP_URL=http://localhost:8001
BEEFREE_CLIENT_ID=
BEEFREE_CLIENT_SECRET=

# FastAPI server bind address
HOST=0.0.0.0
PORT=8000
